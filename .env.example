# ===== 部署环境变量示例 =====
# 复制为 .env 后按需修改；docker compose 会自动加载本目录下的 .env

# ---- 后端 ----
# Node 监听端口（容器内）。改了同时要改 docker-compose 里的暴露端口
PORT=3000

# JWT 签名密钥；生产必须替换成随机长串。可用： openssl rand -hex 32
JWT_SECRET=please-change-me-to-a-long-random-string

# 数据库文件路径（容器内绝对路径，由 data 卷挂载持久化）
DB_FILE=/app/data/exchange.db

# 登录失败限流
LOGIN_FAIL_LIMIT=5
LOGIN_FAIL_WINDOW=600
LOGIN_LOCK_SECONDS=900

# 邮件验证：1=注册即视为已验证（仅本地/调试）；生产保持 0
DEV_AUTO_VERIFY=0
# 1=注册/重发接口在响应里回显验证码（仅本地/调试）；生产保持 0
MAIL_DEV_ECHO=0

# ---- 前端 ----
# 暴露到主机上的 HTTP 端口；阿里云上若直接对外通常用 80（注意安全组放行）
FRONTEND_PORT=80

# ---- 镜像 ----
# GitHub Container Registry 上的镜像名（小写）。
# 例如仓库为 github.com/your-org/captail，则填 ghcr.io/your-org/captail
IMAGE_NAMESPACE=ghcr.io/your-github-username/captail
IMAGE_TAG=latest
