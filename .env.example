# ===== 部署环境变量示例 =====
# 复制为 .env 后按需修改；docker compose 会自动加载本目录下的 .env

# ---- 后端 ----
# Node 监听端口（容器内）。改了同时要改 docker-compose 里的暴露端口
PORT=3000

# JWT 签名密钥；生产必须替换成随机长串。可用： openssl rand -hex 32
JWT_SECRET=please-change-me-to-a-long-random-string

# 数据库文件路径（容器内绝对路径，由 data 卷挂载持久化）
DB_FILE=/app/data/exchange.db

# 登录失败限流
LOGIN_FAIL_LIMIT=5
LOGIN_FAIL_WINDOW=600
LOGIN_LOCK_SECONDS=900

# 邮件验证：1=注册即视为已验证（仅本地/调试）；生产保持 0
DEV_AUTO_VERIFY=0
# 1=注册/重发接口在响应里回显验证码（仅本地/调试）；生产保持 0
MAIL_DEV_ECHO=0

# ---- SMTP 邮件发送 ----
# 发件人显示名与地址（建议保持下面格式）
MAIL_FROM=Captail <captailcn@outlook.com>
# Outlook/Hotmail SMTP 配置
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
# 587 端口用 STARTTLS，保持 0；如改用 465 端口则设为 1
SMTP_SECURE=0
# 登录账号（与 MAIL_FROM 内的邮箱一致）
SMTP_USER=captailcn@outlook.com
# 登录密码：建议使用「应用专用密码」，在 outlook.live.com 安全设置中生成
SMTP_PASS=请填写应用专用密码

# ---- Telegram 通知（用户提现/充值申请时推送到群组） ----
# 留空则后端只在控制台打日志，不实际推送
# 1. 在 BotFather 创建机器人，把 token 填到 TELEGRAM_BOT_TOKEN
# 2. 让超级管理员 @ergouzi_888 把机器人拉入目标群组
# 3. 群里发条消息后访问 https://api.telegram.org/bot<TOKEN>/getUpdates
#    在响应里找到 chat.id（群组通常为负数），填到 TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- 前端 ----
# 暴露到主机上的 HTTP 端口；阿里云上若直接对外通常用 80（注意安全组放行）
FRONTEND_PORT=80

# ---- 镜像 ----
# GitHub Container Registry 上的镜像名（小写）。
# 例如仓库为 github.com/your-org/captail，则填 ghcr.io/your-org/captail
IMAGE_NAMESPACE=ghcr.io/your-github-username/captail
IMAGE_TAG=latest
